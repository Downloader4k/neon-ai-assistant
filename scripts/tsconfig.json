{
    "extends": "../backend/tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "es2019",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "noImplicitAny": false,
        "baseUrl": "..",
        "rootDir": "..",
        "paths": {
            "*": [
                "backend/src/*"
            ]
        }
    },
    "include": [
        "./**/*.ts",
        "../backend/src/**/*.ts"
    ]
}