# ========================================
# Claude API Configuration
# ========================================
ANTHROPIC_API_KEY=your-claude-api-key-here

# ========================================
# Database Configuration
# ========================================
# PostgreSQL
DATABASE_URL=postgresql://neon:neon_password@localhost:5432/neon_db

# Redis
REDIS_URL=redis://localhost:6379

# ChromaDB
CHROMA_URL=http://localhost:8000

# ========================================
# Ollama Configuration
# ========================================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ========================================
# Application Configuration
# ========================================
NODE_ENV=development
PORT=3001
HOST=localhost

# ========================================
# AI Router Configuration
# ========================================
# Komplexitäts-Schwellwert (0-100): Unter diesem Wert wird Ollama verwendet
COMPLEXITY_THRESHOLD=30

# Hybrid-Modus aktivieren (true/false)
ENABLE_HYBRID_MODE=true

# Privacy-Modus (nur lokales Model verwenden)
PRIVACY_MODE=false

# ========================================
# Logging Configuration
# ========================================
LOG_LEVEL=debug
LOG_FILE=logs/neon.log

# ========================================
# Security
# ========================================
# Wird automatisch generiert beim ersten Start
ENCRYPTION_KEY=
