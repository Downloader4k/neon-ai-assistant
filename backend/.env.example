# === NEON AI Assistant — Backend Konfiguration ===

# Server
PORT=3001
HOST=0.0.0.0

# KI
ANTHROPIC_API_KEY=sk-ant-api03-DEIN_KEY_HIER
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b

# Datenbank
DATABASE_URL="file:./prisma/neon.db"

# Optional: Redis
# REDIS_URL="redis://localhost:6379"

# Optional: ChromaDB
# CHROMA_URL="http://localhost:8000"

# Umgebung
NODE_ENV=development

# Verschluesselung
ENCRYPTION_KEY=dein_32_zeichen_schluessel_hier_aendern

# AI Routing — 5-Stufen Orchestrator
ENABLE_ORCHESTRATOR=true
CLAUDE_THRESHOLD=0.85
SELF_CONFIDENCE_THRESHOLD=0.65
COMPLEXITY_THRESHOLD=70

# === Sicherheit (Phase 16) ===
# API-Token fuer Netzwerk-Zugriff (leer = offen/Entwicklungsmodus)
# Setze einen Token um API-Endpoints zu schuetzen:
# API_ACCESS_TOKEN=dein_sicherer_token_hier

# Separater Admin-Token (optional, faellt auf API_ACCESS_TOKEN zurueck)
# ADMIN_ACCESS_TOKEN=dein_admin_token_hier
